[Unit]
Description=ReLab Flask Backend (Gunicorn)
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/relab-backend
Environment="PATH=/opt/relab-backend/.venv/bin"
ExecStart=/opt/relab-backend/.venv/bin/gunicorn --workers 2 --threads 2 --timeout 120 --bind 127.0.0.1:5000 wsgi:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target

